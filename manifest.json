{
  "manifest_version": 3,
  "name": "Prixe",
  "version": "2.0.0",
  "description": "Fast and advanced filtering tool for Steam Search with quick budget presets and local price highlighting.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://www.cheapshark.com/*",
    "https://howlongtobeat.com/*",
    "https://steamspy.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/search*",
        "https://store.steampowered.com/app/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

